# ----------------------------------------------------------------------------
# global environment
# ----------------------------------------------------------------------------

TOPDIR  = $(CURDIR)
CP      = cp
CPFLAGS = -f
RM      = rm
RMFLAGS = -f
PYTHON  = python3
PIO     = pio

# ----------------------------------------------------------------------------
# global targets
# ----------------------------------------------------------------------------

all:
	$(PIO) run

clean:
	$(PIO) run --target clean

upload:
	$(PIO) run --target upload

monitor:
	$(PIO) device monitor --baud 115200

mrproper:
	git clean -f -d -x

